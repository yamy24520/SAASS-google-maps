generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(USER)

  accounts          Account[]
  sessions          Session[]
  businesses        Business[]
  subscription      Subscription?
  passwordResetTokens PasswordResetToken[]
  pushSubscriptions PushSubscription[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── BUSINESS ─────────────────────────────────────────────────────────────────

model Business {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                 String
  category             BusinessCategory @default(RESTAURANT)
  language             String           @default("fr")

  gbpAccountId         String?
  gbpLocationId        String?
  gbpLocationName      String?
  gbpAccessToken       String?          @db.Text
  gbpRefreshToken      String?          @db.Text
  gbpTokenExpiresAt    DateTime?
  gbpConnectedAt       DateTime?

  responseTone         ResponseTone @default(PROFESSIONAL)
  autoReplyEnabled     Boolean      @default(false)
  autoReplyMinRating   Int          @default(4)
  customSignature      String?
  alertEmailEnabled    Boolean      @default(true)

  lastSyncAt           DateTime?
  totalReviews         Int          @default(0)
  averageRating        Float        @default(0)
  responseRate         Float        @default(0)
  placeLat             Float?
  placeLng             Float?
  placeType            String?
  offerEnabled         Boolean  @default(false)
  offerText            String?
  offerType            OfferType        @default(FIXED)
  spinPrizes           Json?
  reputationPageEnabled Boolean @default(false)
  socialLinks          Json?
  logoDataUrl          String? @db.Text
  pageTheme            String  @default("dark")
  pageStyle            String  @default("modern")
  pageTagline          String?
  pageAccentColor      String?
  pageCoverDataUrl     String? @db.Text
  pageDescription      String?
  pageLegalText        String? @db.Text
  pageLabels           Json?
  pageServiceOrder     Json?
  pageShowHours        Boolean @default(false)
  pageSlug             String? @unique
  pageConfig           Json?

  bookingEnabled       Boolean  @default(false)
  bookingHours         Json?
  bookingSettings      Json?
  bookingType          String   @default("appointment") // "appointment" | "restaurant"
  bookingMaxCovers     Int?

  // Stripe Connect
  stripeAccountId      String?  // compte Stripe connecté du propriétaire
  stripeAccountStatus  String?  // "pending" | "active" | "restricted"

  // Sync calendrier
  calendarToken        String?  @unique

  // IA Vocale (Vapi)
  vapiAssistantId  String?
  vapiPhoneNumber  String?
  vapiEnabled      Boolean @default(false)

  pageEvents           PageEvent[]
  services             Service[]
  bookings             Booking[]
  staffs               Staff[]
  closedDates          ClosedDate[]
  waitlistEntries      WaitlistEntry[]
  leadEmails           LeadEmail[]

  reviews              Review[]
  reputationSnapshots  ReputationSnapshot[]
  competitors          Competitor[]
  reviewRequests       ReviewRequest[]
  clientProfiles       ClientProfile[]
  clientSessions       ClientSession[]
  clientOtps           ClientOtp[]

  // Email customization
  emailHeaderUrl       String?
  emailAccentColor     String?
  emailButtonColor     String?
  emailBgColor         String?
  emailGreeting        String?
  emailFooterMessage   String?
  emailSenderName      String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}

enum BusinessCategory {
  RESTAURANT
  HOTEL
  BAR
  CAFE
  SPA
  HAIR_SALON
  BEAUTY
  RETAIL
  SERVICE
  OTHER
}

enum ResponseTone {
  PROFESSIONAL
  FRIENDLY
  LUXURY
  CASUAL
}

// ─── REVIEWS ──────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  googleReviewId    String   @unique
  reviewerName      String
  reviewerPhotoUrl  String?
  rating            Int
  comment           String?  @db.Text
  reviewPublishedAt DateTime

  status         ReviewStatus @default(PENDING)
  isNegative     Boolean      @default(false)
  alertSentAt    DateTime?

  aiDraftResponse    String?  @db.Text
  aiGeneratedAt      DateTime?
  aiPromptTokens     Int?
  aiCompletionTokens Int?

  publishedResponse String?  @db.Text
  publishedAt       DateTime?
  googleReplyName   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, status])
  @@index([businessId, rating])
  @@index([businessId, reviewPublishedAt])
}

enum ReviewStatus {
  PENDING
  DRAFT
  APPROVED
  PUBLISHED
  IGNORED
  FAILED
}

// ─── REPUTATION & COMPETITORS ─────────────────────────────────────────────────

model ReputationSnapshot {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  rating       Float
  reviewCount  Int
  placeId      String?  // Google Place ID
  recordedAt   DateTime @default(now())

  @@index([businessId, recordedAt])
}

model Competitor {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  placeId     String
  rating      Float
  reviewCount Int
  address     String?
  category    String?
  photoUrl    String?
  lastSyncAt  DateTime @default(now())

  @@unique([businessId, placeId])
  @@index([businessId])
}

model ReviewRequest {
  id         String              @id @default(cuid())
  businessId String
  business   Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email      String
  status     ReviewRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  sentAt     DateTime?
  claimToken       String?          @unique
  claimStatus      ClaimStatus      @default(WAITING_REVIEW)
  claimedAt        DateTime?
  prizeWon         String?

  @@index([businessId])
  @@index([status])
}

enum ReviewRequestStatus {
  PENDING
  SENT
}

enum OfferType {
  FIXED
  SPIN_WHEEL
}

enum ClaimStatus {
  WAITING_REVIEW
  CLAIMED
}

// ─── BOOKING ──────────────────────────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String?
  duration    Int      // minutes
  price       Float
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  bookings         Booking[]
  waitlistEntries  WaitlistEntry[]

  @@index([businessId])
}

model Staff {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name          String
  color         String   @default("#0ea5e9")
  active        Boolean  @default(true)
  calendarToken String?  @unique
  createdAt     DateTime @default(now())

  bookings        Booking[]
  absences        StaffAbsence[]
  clientProfiles  ClientProfile[]

  @@index([businessId])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  @@index([userId])
}

model StaffAbsence {
  id        String      @id @default(cuid())
  staffId   String
  staff     Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)
  startDate String      // "2026-04-01"
  endDate   String      // "2026-04-07"
  reason    String?
  type      AbsenceType @default(VACATION)
  createdAt DateTime    @default(now())

  @@index([staffId])
}

enum AbsenceType {
  VACATION
  SICK
  OTHER
}

model Booking {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  staffId     String?
  staff       Staff?   @relation(fields: [staffId], references: [id])

  clientName  String
  clientEmail String
  clientPhone String?
  date        String   // "2026-03-28"
  timeSlot    String   // "09:00"
  status      BookingStatus @default(PENDING)
  notes       String?
  partySize   Int?
  cancelToken      String?   @unique
  reminderSentAt    DateTime?
  smsSentAt         DateTime?   // SMS rappel envoyé
  recurrenceGroupId String?

  // Paiement
  paymentStatus    PaymentStatus @default(NOT_REQUIRED)
  paymentIntentId  String?       // Stripe Checkout Session ID
  depositAmount    Float?        // montant réellement débité

  createdAt        DateTime  @default(now())

  @@index([businessId, date])
  @@index([businessId, status])
  @@index([cancelToken])
  @@index([recurrenceGroupId])
}

model ClosedDate {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  date       String   // "2026-12-25"
  reason     String?  // "Noël", "Congés"
  createdAt  DateTime @default(now())

  @@unique([businessId, date])
  @@index([businessId])
}

model WaitlistEntry {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])

  clientName  String
  clientEmail String
  clientPhone String?
  preferredDate String?   // date souhaitée ou null = "n'importe quand"
  notifiedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([businessId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  NOT_REQUIRED   // paiement non activé
  PENDING        // en attente de paiement
  PAID           // payé
  REFUNDED       // remboursé
  FAILED         // échec
}

// ─── CLIENT PROFILE ───────────────────────────────────────────────────────────

model ClientProfile {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email       String

  notes       String?  @db.Text   // notes privées du pro
  allergies   String?  @db.Text   // allergies déclarées
  preferences String?  @db.Text   // préférences (coupe, couleur, etc.)
  tags        Json?               // ["fidèle", "no-show x2", "VIP"]
  vip         Boolean  @default(false)
  smsOptIn    Boolean  @default(false)

  favoriteStaffId String?
  favoriteStaff   Staff?  @relation(fields: [favoriteStaffId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, email])
  @@index([businessId])
}

// ─── CLIENT SESSION (portail) ─────────────────────────────────────────────────

model ClientSession {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientEmail String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([token])
  @@index([clientEmail, businessId])
}

model ClientOtp {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  clientEmail String
  code        String
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([clientEmail, businessId])
}

model LeadEmail {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email      String
  name       String?
  phone      String?
  source     String   // "booking" | "waitlist" | "review_request"
  createdAt  DateTime @default(now())

  @@unique([businessId, email])
  @@index([businessId])
  @@index([email])
}

// ─── PAGE EVENTS ──────────────────────────────────────────────────────────────

model PageEvent {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type       String   // "view" | "cta_review" | "cta_maps" | "cta_social_facebook" ...
  createdAt  DateTime @default(now())

  @@index([businessId, type])
  @@index([businessId, createdAt])
}

// ─── SUBSCRIPTIONS ────────────────────────────────────────────────────────────

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId       String             @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  status            SubscriptionStatus @default(INACTIVE)
  cancelAtPeriodEnd Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}
